{{ if eq .chezmoi.os "linux" }}
# Linux-specific PATH setup
export PATH="$PATH:$HOME/bin:$HOME/.local/bin:$HOME/.fzf/bin"
[ -d "/home/linuxbrew/.linuxbrew/bin" ] && export PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"

{{ else if eq .chezmoi.os "darwin" }}
# macOS-specific PATH setup
export PATH="$PATH:$HOME/bin:$HOME/.local/bin:$HOME/.fzf/bin"
[ -d "/opt/homebrew/bin" ] && export PATH="/opt/homebrew/bin:$PATH"
{{ end }}

# Auto-start tmux only in interactive shells
if [[ $- == *i* ]] && [ -z "$TMUX" ] && [ -z "$INSIDE_EMACS" ] && [ -z "$VSCODE_INJECTION" ]; then
  username=$(basename "$HOME")
  
  if command -v tmux >/dev/null 2>&1; then
    # Check if session exists
    if tmux has-session -t "$username" 2>/dev/null; then
      exec tmux attach-session -t "$username"
    else
      exec tmux new-session -s "$username" -c "$HOME"
    fi
  else
    echo "Warning: tmux not found. Install it with: brew install tmux (macOS) or apt install tmux (Linux)"
  fi
fi

# Enable Powerlevel10k instant prompt (optional - for faster startup)
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Source Prezto if installed
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Initialize zplug (plugin manager)
if [[ ! -d ~/.zplug ]]; then
    echo "Installing zplug..."
    curl -sL --proto-redir -all,https https://raw.githubusercontent.com/zplug/installer/master/installer.zsh | zsh
fi

if [[ -s ~/.zplug/init.zsh ]]; then
  source ~/.zplug/init.zsh

  # Essential plugins
  zplug "agkozak/zsh-z"                    # Jump to frecent directories
  zplug "junegunn/fzf"                     # Fuzzy finder
  zplug "romkatv/powerlevel10k", as:theme, depth:1  # Theme

  # Install plugins if not installed
  if ! zplug check --verbose; then
      printf "Installing missing zplug plugins...\n"
      zplug install
  fi

  # Load plugins
  zplug load
fi

# Load p10k config if it exists
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Editor settings
export EDITOR='vim'
export VISUAL='vim'
command -v nvim >/dev/null 2>&1 && export EDITOR='nvim' && export VISUAL='nvim'

# Python debugger
export PYTHONBREAKPOINT="IPython.embed"

# Vi mode in shell
bindkey -v
bindkey -M viins 'jk' vi-cmd-mode  # jk to exit insert mode
bindkey -M viins 'kj' vi-cmd-mode  # kj to exit insert mode
bindkey '^p' history-beginning-search-backward
bindkey '^n' history-beginning-search-forward

# Change cursor shape for vi modes
function zle-keymap-select {
  if [[ ${KEYMAP} == vicmd ]] || [[ $1 = 'block' ]]; then
    echo -ne '\e[1 q'  # Block cursor
  elif [[ ${KEYMAP} == main ]] || [[ ${KEYMAP} == viins ]] || [[ ${KEYMAP} = '' ]] || [[ $1 = 'beam' ]]; then
    echo -ne '\e[5 q'  # Beam cursor
  fi
}
zle -N zle-keymap-select

# History settings
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt INC_APPEND_HISTORY        # Write immediately
setopt SHARE_HISTORY             # Share between sessions
setopt HIST_IGNORE_DUPS          # Don't record duplicates
setopt HIST_FIND_NO_DUPS         # Don't show duplicates in search
setopt HIST_IGNORE_SPACE         # Don't record commands starting with space

# FZF settings (if installed)
if command -v fzf >/dev/null 2>&1; then
  [ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
  
  export FZF_DEFAULT_OPTS="
    --height 40%
    --layout=reverse
    --border
    --inline-info
  "
  
  # Use fd instead of find if available
  if command -v fd >/dev/null 2>&1; then
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
  fi
fi

# Tmux session jumping (requires tmux-session script)
tmux_jump() {
    local BASE="$HOME/code/github.com"
    
    if [ ! -d "$BASE" ]; then
        echo "Error: $BASE directory not found"
        return 1
    fi
    
    local SELECTED=$(find "$BASE" -mindepth 2 -maxdepth 2 -type d 2>/dev/null | 
                     sed "s|$BASE/||g" | 
                     fzf --tiebreak=end --select-1 --query="$1")
    
    if [[ $? != 0 ]] || [[ -z "$SELECTED" ]]; then
        echo "Cancelled"
        return 1
    fi
    
    if command -v tmux-session >/dev/null 2>&1; then
        tmux-session "$BASE/$SELECTED"
    else
        echo "Error: tmux-session command not found"
        return 1
    fi
}

# Aliases
alias tj='tmux_jump'
alias ts='tmux-session'
alias gg='lazygit'
alias vim='nvim'
command -v nvim >/dev/null 2>&1 || alias vim='vim'

# SSH with proper terminal
alias ssh='TERM=xterm-256color ssh'

# Chezmoi shortcuts (if installed)
if command -v chezmoi >/dev/null 2>&1; then
  alias chd='cd "$(chezmoi source-path)"'
  alias cha='chezmoi apply'
fi

# IPython shortcut
alias ipython="python -c 'import IPython; IPython.terminal.ipapp.launch_new_instance()'"

# Load local customizations if they exist
[ -f ~/.zshrc_local ] && source ~/.zshrc_local
[ -f ~/.profile ] && source ~/.profile

# Notes directory (if using zk or similar)
export NOTES_DIR="$HOME/notes"
export ZK_NOTEBOOK_DIR="$NOTES_DIR/.zk"
